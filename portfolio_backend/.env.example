# Copy to .env and fill in values
# Never commit your real .env

NEWSAPI_KEY=
FINNHUB_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
REDIS_URL=redis://localhost:6379/0
ALERT_EMAIL_TO=
ALERT_PRICE_THRESHOLD=1000
ALERT_DROP_PCT=5
ALERT_CAPITAL_THRESHOLD=10000
ALERT_SMS_TO=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
PENNY_SUBREDDITS=pennystocks+wallstreetbets
PENNY_MAX_SYMBOLS=20

# Continuous evaluation windows
EVAL_WINDOW_DAYS=7
DRIFT_BASELINE_DAYS=30

# Retrain holdout guardrails
PAPER_TRADE_HOLDOUT_RATIO=0.2
PAPER_TRADE_MIN_HOLDOUT_ACCURACY=0.55
PAPER_TRADE_HOLDOUT_DAYS=0
PAPER_TRADE_MIN_HOLDOUT_SAMPLES=10

# TaskRunLog retention
TASKRUNLOG_RETENTION_DAYS=30

# Drift retrain thresholds
DRIFT_PSI_THRESHOLD=0.2
DRIFT_LOOKBACK_DAYS=1
WATCHLIST_DRIFT_PSI_THRESHOLD=0.2
AI_BLUECHIP_DRIFT_PSI_THRESHOLD=0.2
AI_PENNY_DRIFT_PSI_THRESHOLD=0.2

# Sandbox-specific rollback overrides (optional)
WATCHLIST_ROLLBACK_MIN_WIN_RATE=0.45
WATCHLIST_ROLLBACK_MAX_BRIER=0.35
WATCHLIST_ROLLBACK_LOOKBACK_DAYS=3
AI_BLUECHIP_ROLLBACK_MIN_WIN_RATE=0.45
AI_BLUECHIP_ROLLBACK_MAX_BRIER=0.35
AI_BLUECHIP_ROLLBACK_LOOKBACK_DAYS=3
AI_PENNY_ROLLBACK_MIN_WIN_RATE=0.45
AI_PENNY_ROLLBACK_MAX_BRIER=0.35
AI_PENNY_ROLLBACK_LOOKBACK_DAYS=3
