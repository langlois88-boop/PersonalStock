# Copy to .env and fill in values
# Never commit your real .env

NEWSAPI_KEY=
FINNHUB_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
REDIS_URL=redis://localhost:6379/0
ALERT_EMAIL_TO=
ALERT_PRICE_THRESHOLD=1000
ALERT_DROP_PCT=5
ALERT_CAPITAL_THRESHOLD=10000
ALERT_COOLDOWN_HOURS=12
ETF_SYMBOLS=TEC.TO
USD_CAD_RATE=1.36
ALERT_SMS_TO=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
PENNY_SUBREDDITS=pennystocks+wallstreetbets
PENNY_MAX_SYMBOLS=20

# Continuous evaluation windows
EVAL_WINDOW_DAYS=7
DRIFT_BASELINE_DAYS=30

# Backtester & training
BACKTEST_SYMBOL=SPY
BACKTEST_LOOKBACK_DAYS=90
BACKTEST_MIN_WIN_RATE=52
BACKTEST_TX_COST_PCT=0.002
BACKTEST_SLIPPAGE_PCT=0.001
BACKTEST_MONTE_CARLO_RUNS=1000
BACKTEST_RUIN_THRESHOLD_PCT=0.6
TRIPLE_BARRIER_UP_PCT=0.05
TRIPLE_BARRIER_DOWN_PCT=0.03
TRIPLE_BARRIER_MAX_DAYS=20
TIME_SERIES_SPLITS=4

# Retrain holdout guardrails
PAPER_TRADE_HOLDOUT_RATIO=0.2
PAPER_TRADE_MIN_HOLDOUT_ACCURACY=0.55
PAPER_TRADE_HOLDOUT_DAYS=0
PAPER_TRADE_MIN_HOLDOUT_SAMPLES=10

# TaskRunLog retention
TASKRUNLOG_RETENTION_DAYS=30

# Drift retrain thresholds
DRIFT_PSI_THRESHOLD=0.2
DRIFT_LOOKBACK_DAYS=1
WATCHLIST_DRIFT_PSI_THRESHOLD=0.2
AI_BLUECHIP_DRIFT_PSI_THRESHOLD=0.2
AI_PENNY_DRIFT_PSI_THRESHOLD=0.2

# Sandbox-specific rollback overrides (optional)
WATCHLIST_ROLLBACK_MIN_WIN_RATE=0.45
WATCHLIST_ROLLBACK_MAX_BRIER=0.35
WATCHLIST_ROLLBACK_LOOKBACK_DAYS=3
AI_BLUECHIP_ROLLBACK_MIN_WIN_RATE=0.45
AI_BLUECHIP_ROLLBACK_MAX_BRIER=0.35
AI_BLUECHIP_ROLLBACK_LOOKBACK_DAYS=3
AI_PENNY_ROLLBACK_MIN_WIN_RATE=0.45
AI_PENNY_ROLLBACK_MAX_BRIER=0.35
AI_PENNY_ROLLBACK_LOOKBACK_DAYS=3

# AI bluechip sandbox
AI_BLUECHIP_CAPITAL=10000
AI_BLUECHIP_BUY_THRESHOLD=0.85
AI_BLUECHIP_SELL_THRESHOLD=0.65
AI_BLUECHIP_TRAIL_PCT=0.05
AI_BLUECHIP_VOLUME_ZSCORE_MIN=0.5
AI_BLUECHIP_MONTHLY_CONTRIBUTION=2300
AI_BLUECHIP_REINFORCE_MIN_SCORE=0.85

# AI penny sandbox
AI_PENNY_CAPITAL=10000
AI_PENNY_POSITION_CAP_PCT=0.02
AI_PENNY_MIN_ALTMAN_Z=2.0
